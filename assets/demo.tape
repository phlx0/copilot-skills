Output assets/demo.gif

Set FontSize 15
Set Width 1000
Set Height 560
Set Theme "Catppuccin Mocha"
Set Shell "bash"
Set Padding 24
Set TypingSpeed 40ms
Set CursorBlink false

Hide
Type "alias copilot-skills='node /Users/phlx/projects/copilot-skills/bin/copilot-skills.js'"
Enter
Type "node /Users/phlx/projects/copilot-skills/bin/copilot-skills.js remove brainstorming 2>/dev/null; clear"
Enter
Sleep 1s
Show

Type "copilot-skills search design"
Sleep 300ms
Enter
Sleep 4s

Type "copilot-skills info brainstorming"
Sleep 300ms
Enter
Sleep 3s

Type "copilot-skills add brainstorming"
Sleep 300ms
Enter
Sleep 5s

Type "copilot-skills list"
Sleep 300ms
Enter
Sleep 3s

Sleep 2s
